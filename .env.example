# Copy to .env and fill in. NEVER commit .env (it's gitignored).

# --- LLM provider (Cognee uses this to build the knowledge graph) ---
# OpenAI key, or your provider's key
LLM_API_KEY=
# LLM_PROVIDER=openai
# LLM_MODEL=gpt-4o-mini            # cheap + good enough for graph extraction

# --- OPEN SOURCE option A: Groq (hosted open-source models) ---
# Free-tier hosted API serving open-source Llama models on Groq's LPU hardware.
# Dramatically faster than local Ollama (seconds vs minutes per extraction call).
# Get a free key at console.groq.com. Also install the groq package: pip install groq
#
# LLM_PROVIDER=custom
# LLM_MODEL=groq/llama-3.1-8b-instant
# NOTE: llama-3.3-70b-versatile has a 100k tokens/day cap that heavy testing
# can exhaust fast. llama-3.1-8b-instant uses a separate daily quota bucket
# (though its own per-minute cap, 6k TPM, is tighter). If you hit rate limits
# on either, the app degrades gracefully (cached answers + a 25s timeout with
# a friendly "temporarily busy" message) rather than hanging. For a live demo,
# a paid Groq Dev Tier key removes this risk entirely.
# LLM_ENDPOINT=https://api.groq.com/openai/v1
# LLM_API_KEY=gsk_...
# LLM_INSTRUCTOR_MODE=tool_call
# VISION_MODEL=llava-v1.5-7b-4096-preview  # Groq vision model (llava)
# LLM_TRANSCRIPTION_MODEL=whisper-large-v3 # Groq audio transcription model
# COGNEE_SKIP_CONNECTION_TEST=true

# --- OPEN SOURCE option B: local Ollama (current default) ---
# Fully offline, zero API key, zero cloud. All LLM inference runs locally.
# CPU-only inference is slower (30-90s per extraction call) but free and private.
# LLM_PROVIDER=ollama
# LLM_MODEL=gemma4:e4b               # text/graph extraction model
# LLM_ENDPOINT=http://localhost:11434/v1
# LLM_API_KEY=ollama_dummy_key       # must be non-empty to activate LIVE mode
# LLM_INSTRUCTOR_MODE=json_mode      # avoids tool-call overhead on thinking models
# LLM_MAX_COMPLETION_TOKENS=16384    # raise Ollama's default 4096 cap
# COGNEE_SKIP_CONNECTION_TEST=true   # skip 30s pre-flight probe
#
# --- Vision model (image / video / scanned-PDF ingestion) ---
# Image/video/scanned-PDF ingestion uses a separate local vision-capable model.
# After pulling with `ollama pull llava:7b`, set these:
# VISION_MODEL=llava:7b              # or moondream, minicpm-v, llava:13b, etc.
# OLLAMA_BASE_URL=http://localhost:11434

# --- Automatic Groq -> local-model fallback (multimodal + Cognee text/graph) ---
# When Groq is rate-limited/out of quota, the backend automatically retries
# against a local Ollama install instead of failing the request:
#   • Vision (images + video frames): falls back to `moondream` (small, fast,
#     vision-capable — `ollama pull moondream`).
#   • Audio transcription: falls back to local Whisper (already bundled, no
#     extra pull needed).
#   • Cognee's own text/graph completions (chat, recall, interrogation,
#     whatif, graph insights): falls back to a local text model (default
#     llama3.1:8b) if Groq errors OR returns a degraded/empty reply.
# Requires `ollama serve` running locally. Override the endpoint/models below
# if you're not using the defaults:
# OLLAMA_ENDPOINT=http://localhost:11434/v1
# OLLAMA_VISION_MODEL=moondream
# OLLAMA_TEXT_MODEL=llama3.1:8b

# --- Self-hosted backends (Best Use of OPEN SOURCE track) ---
# Defaults are local/embedded; uncomment to pin them explicitly.
# VECTOR_DB_PROVIDER=lancedb
# GRAPH_DATABASE_PROVIDER=kuzu
# DB_PROVIDER=sqlite
#
# NOTE: embedded LanceDB has a known concurrency bug on some machines
# ("Spill has sent an error" during merge_insert under async writes).
# If you hit it, switch to Postgres/pgvector instead (see README
# Troubleshooting) and set ENABLE_BACKEND_ACCESS_CONTROL=false —
# Cognee's multi-tenant mode silently forces embedded LanceDB regardless
# of VECTOR_DB_PROVIDER unless that's disabled.

# --- Embeddings for the naive baseline (runs locally, no key needed) ---
# BASELINE_EMBED_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Disables Cognee's default per-turn session-memory analysis (an extra structured-output LLM
# call before every search()) — set false to skip it, which meaningfully speeds up local-Ollama
# fallback attempts (local CPU inference is much slower per-call than hosted Groq).
CACHING=false
