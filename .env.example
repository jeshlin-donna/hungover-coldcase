# Copy to .env and fill in. NEVER commit .env (it's gitignored).

# --- LLM provider (Cognee uses this to build the knowledge graph) ---
# OpenAI key, or your provider's key
LLM_API_KEY=
# LLM_PROVIDER=openai
# LLM_MODEL=gpt-4o-mini            # cheap + good enough for graph extraction

# --- OPEN SOURCE option A: Groq (recommended) ---
# Free-tier hosted API serving open-source Llama models on Groq's own LPU
# hardware. Same open-source model family as local Ollama, but hosted —
# no local CPU/RAM pressure and dramatically faster (seconds, not minutes,
# per structured-extraction call). Get a free key at console.groq.com.
# Cognee routes through litellm, which requires the `groq/` prefix on the
# model name for correct request routing.
# LLM_PROVIDER=custom
# LLM_MODEL=groq/llama-3.3-70b-versatile
# LLM_ENDPOINT=https://api.groq.com/openai/v1
# LLM_API_KEY=gsk_...
# LLM_INSTRUCTOR_MODE=tool_call
# COGNEE_SKIP_CONNECTION_TEST=true  # Cognee's own pre-flight LLM ping times
                                    # out against the generic/custom adapter
                                    # even though the endpoint works fine —
                                    # confirmed via direct curl. Safe to skip.

# --- OPEN SOURCE option B: local Ollama (current default) ---
# Fully offline, zero API key, zero cloud. All LLM inference runs locally.
# CPU-only inference is slower (30-90s per extraction call) but free and private.
# LLM_PROVIDER=ollama
# LLM_MODEL=gemma4:e4b               # text/graph extraction model
# LLM_ENDPOINT=http://localhost:11434/v1
# LLM_API_KEY=ollama_dummy_key       # must be non-empty to activate LIVE mode
# LLM_INSTRUCTOR_MODE=json_mode      # avoids tool-call overhead on thinking models
# LLM_MAX_COMPLETION_TOKENS=16384    # raise Ollama's default 4096 cap
# COGNEE_SKIP_CONNECTION_TEST=true   # skip 30s pre-flight probe
#
# --- Vision model (image / video / scanned-PDF ingestion) ---
# Image/video/scanned-PDF ingestion uses a separate local vision-capable model.
# After pulling with `ollama pull llava:7b`, set these:
# VISION_MODEL=llava:7b              # or moondream, minicpm-v, llava:13b, etc.
# OLLAMA_BASE_URL=http://localhost:11434

# --- Self-hosted backends (Best Use of OPEN SOURCE track) ---
# Defaults are local/embedded; uncomment to pin them explicitly.
# VECTOR_DB_PROVIDER=lancedb
# GRAPH_DATABASE_PROVIDER=kuzu
# DB_PROVIDER=sqlite
#
# NOTE: embedded LanceDB has a known concurrency bug on some machines
# ("Spill has sent an error" during merge_insert under async writes).
# If you hit it, switch to Postgres/pgvector instead (see README
# Troubleshooting) and set ENABLE_BACKEND_ACCESS_CONTROL=false —
# Cognee's multi-tenant mode silently forces embedded LanceDB regardless
# of VECTOR_DB_PROVIDER unless that's disabled.

# --- Embeddings for the naive baseline (runs locally, no key needed) ---
# BASELINE_EMBED_MODEL=sentence-transformers/all-MiniLM-L6-v2
