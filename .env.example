# Copy to .env and fill in. NEVER commit .env (it's gitignored).

# -----------------------------------------------------------------------------
# Primary LLM path for Cognee text extraction / graph query
# -----------------------------------------------------------------------------

# Set this to a real provider key, or to a non-empty dummy value for local Ollama mode.
LLM_API_KEY=

# Groq / hosted open-source example (recommended for speed)
# LLM_PROVIDER=custom
# LLM_MODEL=groq/llama-3.1-8b-instant
# LLM_ENDPOINT=https://api.groq.com/openai/v1
# LLM_API_KEY=gsk_...
# LLM_INSTRUCTOR_MODE=tool_call
# COGNEE_SKIP_CONNECTION_TEST=true
# LLM_VISION_MODEL=llava-v1.5-7b-4096-preview
# LLM_TRANSCRIPTION_MODEL=whisper-large-v3

# Fully local Ollama example
# LLM_PROVIDER=ollama
# LLM_MODEL=gemma4:e4b
# LLM_ENDPOINT=http://localhost:11434/v1
# LLM_API_KEY=ollama_dummy_key   # must be non-empty for LIVE mode
# LLM_INSTRUCTOR_MODE=json_mode
# LLM_MAX_COMPLETION_TOKENS=16384
# COGNEE_SKIP_CONNECTION_TEST=true

# -----------------------------------------------------------------------------
# Embeddings
# -----------------------------------------------------------------------------

# Fast local baseline embeddings
# EMBEDDING_PROVIDER=fastembed
# EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
# EMBEDDING_DIMENSIONS=384

# Local Ollama embeddings
# EMBEDDING_PROVIDER=ollama
# EMBEDDING_MODEL=nomic-embed-text:latest

# -----------------------------------------------------------------------------
# Vision / audio models
# -----------------------------------------------------------------------------

# Local vision-capable Ollama server
# OLLAMA_BASE_URL=http://localhost:11434
# VISION_MODEL=llava:7b

# Groq-specific multimodal overrides
# LLM_VISION_MODEL=llava-v1.5-7b-4096-preview
# LLM_TRANSCRIPTION_MODEL=whisper-large-v3

# -----------------------------------------------------------------------------
# Automatic Groq -> local fallback
# -----------------------------------------------------------------------------

# When Groq is rate-limited or returns a degraded reply, ColdCache can retry
# against a local Ollama install.
# OLLAMA_ENDPOINT=http://localhost:11434/v1
# OLLAMA_VISION_MODEL=moondream
# OLLAMA_TEXT_MODEL=llama3.1:8b
# COLDCACHE_RECALL_TIMEOUT_S=25
# COLDCACHE_FALLBACK_TIMEOUT_S=75
# COLDCACHE_LOCAL_FALLBACK_TIMEOUT_S=55
# COLDCACHE_LLM_RETRY_FLOOR_S=8

# Disables Cognee's extra per-turn session-memory analysis call, which makes
# local fallback noticeably faster.
CACHING=false

# Optional recall-cache tuning for repeated legacy/global queries
# COLDCACHE_CACHE_DIR=.cognee_data
# COLDCACHE_DISABLE_RECALL_CACHE=false

# -----------------------------------------------------------------------------
# Cognee storage backends (advanced / optional)
# -----------------------------------------------------------------------------

# VECTOR_DB_PROVIDER=lancedb
# GRAPH_DATABASE_PROVIDER=kuzu
# DB_PROVIDER=sqlite

# Optional pgvector workaround path for embedded LanceDB issues
# VECTOR_DB_PROVIDER=pgvector
# VECTOR_DB_HOST=localhost
# VECTOR_DB_PORT=5432
# VECTOR_DB_USERNAME=<postgres-user>
# VECTOR_DB_PASSWORD=<postgres-password>
# VECTOR_DB_NAME=coldcache
# ENABLE_BACKEND_ACCESS_CONTROL=false

# -----------------------------------------------------------------------------
# Deployment-only examples (Render disk mounts, usually set by the platform)
# -----------------------------------------------------------------------------

# DATA_ROOT_DIRECTORY=/opt/render/project/cognee_data/data_storage
# SYSTEM_ROOT_DIRECTORY=/opt/render/project/cognee_data/cognee_system
# CACHE_ROOT_DIRECTORY=/opt/render/project/cognee_data/cognee_cache

# Note: the current case-persistence layer does not require extra app env vars.
# It always stores durable app data in data/coldcache.db and data/cases/.

# -----------------------------------------------------------------------------
# Public-deployment hardening (all optional; safe no-ops for local dev)
# -----------------------------------------------------------------------------

# Comma-separated list of extra allowed frontend origins for CORS, on top of the
# built-in localhost:5173 dev defaults. Set this to your deployed Vercel URL.
# ALLOWED_ORIGINS=https://your-app.vercel.app

# Shared secret required (via the X-Admin-Token header) for destructive/global
# routes: GET /cases (list-all), POST /expunge. Leave unset for local dev — the
# check becomes a no-op. Set this before exposing the backend publicly.
# ADMIN_TOKEN=<a-long-random-string>

# Per-IP requests/minute allowed on upload, analyze, and transcribe routes.
# Defaults to 20; set to 0 to disable.
# RATE_LIMIT_MAX_PER_MINUTE=20

