# Copy to .env.production on the server and never commit the filled file.
DOMAIN=coldcache.example.com
BASIC_AUTH_USER=investigator
# Generate with: docker run --rm caddy:2-alpine caddy hash-password --plaintext 'change-me'
# Keep the value single-quoted so Docker Compose treats $ characters literally.
BASIC_AUTH_HASH='$2a$14$replace_with_generated_bcrypt_hash'

LLM_PROVIDER=custom
LLM_MODEL=groq/llama-3.1-8b-instant
LLM_ENDPOINT=https://api.groq.com/openai/v1
LLM_API_KEY=gsk_replace_me
LLM_INSTRUCTOR_MODE=tool_call
COGNEE_SKIP_CONNECTION_TEST=true
LLM_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
LLM_TRANSCRIPTION_MODEL=whisper-large-v3

EMBEDDING_PROVIDER=fastembed
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIMENSIONS=384
CACHING=false
COLDCACHE_LLM_RETRY_FLOOR_S=8
LLM_CASE_MAX_TOKENS=1600

# To use xAI Grok instead of Groq, replace the LLM_* values above with:
# LLM_PROVIDER=custom
# LLM_MODEL=xai/grok-4.3
# LLM_ENDPOINT=https://api.x.ai/v1
# LLM_API_KEY=xai_replace_me
